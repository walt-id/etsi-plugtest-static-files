{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/.well-known/schemas/birth-certificate-pub-eaa-v1.schema.json",
  "title": "Birth Certificate PuB-EAA (SD-JWT VC) - v1",
  "type": "object",
  "additionalProperties": true,

  "required": [
    "vct",
    "issuing_authority",
    "issuing_country",
    "expiry_date",
    "given_name",
    "family_name",
    "date_of_birth",
    "place_of_birth",
    "parents"
  ],

  "properties": {
    "vct": {
      "type": "string",
      "const": "urn:example:eaa:birth_certificate:1",
      "description": "Verifiable Credential Type identifier."
    },

    "iss": { "type": "string", "format": "uri" },
    "iat": { "type": "integer", "minimum": 0 },
    "nbf": { "type": "integer", "minimum": 0 },
    "exp": { "type": "integer", "minimum": 0 },
    "jti": { "type": "string" },

    "eaa_category": {
      "type": "string",
      "description": "EAA category marker (e.g., PuB-EAA).",
      "enum": ["PuB-EAA", "QEAA", "EAA"]
    },

    "status": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status_list": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "uri": { "type": "string", "format": "uri" },
            "idx": { "type": "integer", "minimum": 0 }
          },
          "required": ["uri", "idx"]
        }
      }
    },

    "cnf": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "jwk": { "type": "object", "additionalProperties": true }
      }
    },

    "issuing_authority": { "type": "string", "minLength": 1 },
    "issuing_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 recommended."
    },
    "expiry_date": { "type": "string", "format": "date" },

    "given_name": { "type": "string", "minLength": 1 },
    "family_name": { "type": "string", "minLength": 1 },
    "date_of_birth": { "type": "string", "format": "date" },

    "sex": { "type": "string", "enum": ["M", "F", "X", "U"] },

    "place_of_birth": {
      "type": "object",
      "additionalProperties": true,
      "required": ["locality", "country"],
      "properties": {
        "locality": { "type": "string", "minLength": 1 },
        "region": { "type": "string" },
        "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
      }
    },

    "birth_record": {
      "type": "object",
      "additionalProperties": true,
      "required": ["entry_number", "entry_date"],
      "properties": {
        "register_name": { "type": "string" },
        "entry_number": { "type": "string", "minLength": 1 },
        "entry_date": { "type": "string", "format": "date" }
      }
    },

    "parents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["relation", "given_name", "family_name"],
        "properties": {
          "relation": { "type": "string", "enum": ["mother", "father", "parent"] },
          "given_name": { "type": "string", "minLength": 1 },
          "family_name": { "type": "string", "minLength": 1 }
        }
      }
    },

    "notes": { "type": "string" }
  }
}